# Best Practice: Specific version with minimal alpine base
FROM node:18.19.0-alpine

# Best Practice: Install only security updates
RUN apk update && apk upgrade && apk add --no-cache \
    dumb-init \
    && rm -rf /var/cache/apk/*

# Best Practice: Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

WORKDIR /app

# Best Practice: Copy only necessary files
COPY --chown=nodejs:nodejs package*.json ./

# Best Practice: Run as non-root for package install
USER nodejs

RUN npm ci --only=production

COPY --chown=nodejs:nodejs . .

# Best Practice: Only expose necessary port
EXPOSE 8080

# Best Practice: Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD node healthcheck.js || exit 1

# Best Practice: Use exec form and dumb-init
ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["node", "server.js"]